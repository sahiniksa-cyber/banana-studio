# ===== إعدادات استوديو الصور =====
# الطريقة الموصى بها: ضع المفاتيح كمتغيّرات بيئة في Railway (لا تظهر في المنصة).
# لها الأولوية على أي مفتاح مُدخَل من واجهة التطبيق.

# مفتاح GPT-Image (OpenAI) — يبدأ بـ sk-
# OPENAI_API_KEY=sk-...

# مفتاح Nano Banana (Google Gemini) — يبدأ بـ AIza
# GEMINI_API_KEY=AIza...

# مجلد حفظ البيانات (قاعدة البيانات + الصور + الإعدادات).
# على الاستضافة اربطه بقرص دائم (Volume) حتى لا تُفقد البيانات.
# DATA_DIR=/data

# منفذ التشغيل (افتراضي 5001 محليًا). أغلب منصات الاستضافة تحقنه تلقائيًا.
# PORT=5001
